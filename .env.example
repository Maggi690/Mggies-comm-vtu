APP_NAME="Universal VTU Pro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.universalvtupro.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=universal_vtu_pro
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@universalvtupro.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,app.universalvtupro.com

# JWT
JWT_SECRET=
JWT_TTL=60

# Encryption
ENCRYPTION_KEY=

# Monnify
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://api.monnify.com
MONNIFY_WEBHOOK_SECRET=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_WEBHOOK_SECRET=

# Paga
PAGA_API_KEY=
PAGA_SECRET_KEY=
PAGA_BASE_URL=https://www.mypaga.com

# VTU Providers (Slots for multiple)
VTU_PRIMARY_PROVIDER=vtpass
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_BASE_URL=https://vtpass.com/api

HUSMODATA_API_KEY=
HUSMODATA_BASE_URL=https://husmodata.com/api

GSUBZ_API_KEY=
GSUBZ_BASE_URL=https://gsubz.com/api

# Notifications
